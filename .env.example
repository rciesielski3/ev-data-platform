# Neon PostgreSQL connection string (PostGIS enabled)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Optional: Bearer token for protected cron import endpoints
CRON_SECRET=""

# Optional: EIPA export access key
EIPA_EXPORT_KEY=""

# Optional: limit EIPA import size for testing
EIPA_IMPORT_LIMIT=""

# Optional: OpenEV data source URL override
OPENEV_DATA_URL=""
