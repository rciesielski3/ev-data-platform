{
  "name": "evsource",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "validate:quick": "npm run lint && npm run typecheck && npm run test",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "import:eipa": "tsx src/server/jobs/run-eipa-import.ts",
    "import:eipa:test": "EIPA_IMPORT_LIMIT=100 npm run import:eipa",
    "import:openev": "tsx src/server/jobs/run-openev-import.ts",
    "import:all": "npm run import:eipa && npm run import:openev",
    "snapshot:backfill": "tsx src/server/jobs/backfill-snapshot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "^15.3.3",
    "next-intl": "^4.13.0",
    "react": "^19.1.0",
    "react-countup": "^6.5.3",
    "react-dom": "^19.1.0",
    "recharts": "^3.9.0",
    "simple-icons": "^16.24.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.5.20",
    "husky": "^9.1.7",
    "postcss": "^8.5.15",
    "prisma": "^6.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
